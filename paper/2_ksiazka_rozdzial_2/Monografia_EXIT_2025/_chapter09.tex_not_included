\subsubsection{Block properties}\index{block
properties}\label{et_block_properties}

For the \textit{TWET-no-idle }problem, each schedule of jobs can
be represented by permutation $\pi = (\pi (1),\pi (2),\ldots,\pi
(n))$ of elements of the set of jobs $\st{J}$. Let $\Phi_n$ denote
the set of all such permutations. The total cost $\pi \in \Phi_n$
is $F(\pi ) = \sum\nolimits_{i = 1}^n {f_{\pi (i)} (C_{\pi (i)} )}
,$ where $C_{\pi (i)} $ is completed time of the job $\pi (i),
C_{\pi (i)} = \sum\nolimits_{j = 1}^i {p_{\pi (j)} } $. The job
$\pi (i)$ is considered \textit{early} if it is completed before
its earliest moment of finishing ($C_{\pi (i)} < e_{\pi (i)} )$,
\textit{on time} if $e_{\pi (i)} \le C_{\pi (i)} \le d_{\pi (i)}
$, and \textit{tardy} if the job is completed after its due date
(i.e. $C_{\pi (i)} > d_{\pi (i)} )$.

Each permutation $\pi \in \Phi_n$ is decomposed into
subpermutations (subsequences of jobs) $B = (B^1 ,B^2 ,\ldots,B^v
)$ called \textit{blocks} in $\pi $, where:
%\vspace{-5mm}
\begin{enumerate}
\item $ B^i = (\pi (a_i ),\pi (a_i + 1),\ldots,\pi (b_i - 1),\pi
(b_i )), $ and \\ $a_i = b_{i - 1} + 1,\;\;1 \le i \le v,\;\;a_0 =
0,\;b_v = n. $
\item All the jobs $j \in B^i $ satisfy the following conditions:\\
%\noindent
%\vspace*{-6mm}
%\begin{table}[htbp]
\begin{tabular}{ll}
\hspace*{1mm}$e_j > C_{\pi (b_i )} ,$&(C1)\\
\hspace*{1mm}$e_j \le C_{\pi (b_{i - 1} )} + p_j$ and $d_j \ge C_{\pi (b_i )},\quad$&(C2)\\
\hspace*{1mm}$d_j < C_{\pi (b_{i - 1} )} + p_j.$&(C3)\\
\end{tabular}
%\end{table}
%\vspace*{-6mm}
%
%\noindent Cleary, each job $j \in B_i $ satisfying Condition $C1$ is a \textit{early}, Condition C2 is a
%\textit{on time} and Condition C3 is a \textit{tardy}.
\item $B_i$ are maximal subsequences of $\pi $ in which all the
jobs satisfy either Condition $C1$ or Condition $C2$ or Condition
$C3$.
\end{enumerate}
%
\noindent By definition, there exist three types of blocks implied
by either C1 or C2 or C3. To distinguish them, we will use the
\textit{E-block}, \textit{O-block} and \textit{T-block} notions
respectively. For any block $\Upsilon$ in a partition $B$ of
permutation $\pi \in \Phi_n$, let
%\vspace{-6mm}
\begin{equation}
F_\Upsilon (\pi ) = \sum\nolimits_{i \in \Upsilon} {(u_i E_i + w_i
T_i )}. \end{equation}

%\vspace{-2mm}

\noindent Therefore, the value of a goal function
%\vspace{-6mm}
\begin{equation}
F(\pi ) = \sum\nolimits_{i = 1}^n {(u_i E_i + w_i T_i )} =
\sum\nolimits_{\Upsilon \in B } {F_\Upsilon (\pi )}.
\end{equation}

%\vspace{-2mm}

\noindent If $\Upsilon$ is a $T$-block, then every job inside is
early. Therefore, an optimal sequence of the jobs within
$\Upsilon$ of the permutation $\pi $ (that is minimizing
$F_\Upsilon (\pi ))$ can be obtained, using the well-known
Weighted Shortest Processing Time (\emph{WSPT}) rule, proposed by
Smith \cite{smith}. The \emph{WSPT} rule creates an optimal
sequence of jobs in the non-increasing order of the ratios $w_j /
p_j $. Similarly, if $\Upsilon$ is an $E$-block, than an optimal
sequence of the jobs within can be obtained, using the Weighted
Longest Processing Time (\emph{WLPT}) rule which creates a
sequence of jobs in the non-decreasing order of the ratios $u_j /
p_j $.
%
Partition $B$ of the permutation $\pi $ is \textit{ordered}, if
there are jobs in the \emph{WSPT} sequence in any $T$-block, and
if there are jobs in the \emph{WLPT} sequence in any $E$-block.

\begin{tw}[\cite{Boz}]\label{tw_a} Let $\Upsilon$ be an ordered partition of a permutation $\pi
\in \Phi_n$ to blocks. If $\beta \in \Phi_n$ and $F(\beta ) <
F(\pi )$, so at least one job of some block of $\pi $ was moved
before the first or after the last job of this block in the
permutation $\beta $.
\end{tw}

%\vspace{-2mm}
\noindent Note that Theorem \ref{tw_a} provides the necessary
condition to obtain a permutation $\beta $ from $\pi $ such, that
$F(\beta ) < F(\pi )$.
%
Let $B = (B^1 ,B^2 ,\ldots,B^v )$ be an ordered partition of the
permutation $\pi \in \Phi_n$ to blocks. If a job $\pi (j) \in B^i
\;(B^i \in B)$, therefore moves which can improving goal function
value consists in reordering a job $\pi (j)$ before the first or
after the last job of this block. Let $N_j^{bf} $ and $N_j^{af} $
be sets of such moves ($N_j^{bf} = \emptyset$ for $j \in B^1$ and
$N_j^{af} = \emptyset$ for $j \in B^v$). Therefore,
the neighborhood of the permutation $\pi \in \Phi_n$, %\vspace{-3mm}
\begin{equation}
\label{eq1} N(\pi ) = \bigcup\limits_{j = 1}^n {N_j^{bf} \cup }
\bigcup\limits_{j = 1}^n {N_j^{af} }.
\end{equation}
%\vspace{-3mm}
As computational experiments show, the neighborhood defined in
(\ref{eq1}) has a half smaller size than the neighborhood of all
the insert moves.



\section{Memetic algorithm}


All operations in a coevolutionary memetic algorithm (selection,
cross\-over, local optimization and succession) are executed
locally, on some subsets of the current population called
\textit{islands}. It is a strongly decentralized model of an
evolutionary algorithm. There are independent evolution processes
on each of the islands, and communication takes place
sporadically. Exchanging individuals between islands secures
diversity of populations and prevents fast imitating of an
individual with a local minimum as its goal function. On each
island a hybrid algorithm is applied, in which an evolutionary
algorithm is used to determine the starting solutions for the
local search algorithm. Algorithm~\ref{fig_Memetic algorithm} 
on page \pageref{fig_Memetic algorithm} contains the outline of 
the classic memetic algorithm.


\begin{algorithm}[h!]
\label{fig_Memetic algorithm}
	\caption{Memetic algorithm}

Number of iteration $k:=$0;

$P_0\leftarrow $initial population;

$\pi^* = \arg\min_{\pi \in P_0} f(\pi)$;

\Repeat{termination condition is satisfied}{
    $P_k^{\prime} \leftarrow $Selection($P_k )$;\\

    $P_k^{\prime\prime} \leftarrow $Crossover($P_k^{\prime})$;\\

    $P_k^{\prime\prime} \leftarrow $Mutation($P_k^{\prime\prime} )$;\\

    $A \leftarrow $RandomSubSet($P_k^{\prime\prime} )$;\\

    $P_k^{\prime\prime} \leftarrow $ $P_k^{\prime\prime} \cup $LocalMinimumSet($A$);\\

    $P_{k + 1} \leftarrow $Succession($P_k,\;P_k^{\prime\prime})$\\
    
    $k:=k$ + 1;\\
    
    \If{$\min_{\pi \in P_k} f(\pi) < f(\pi^*)$}{$\pi^* \leftarrow \arg\min_{\pi \in P_k} f(\pi)$;}
}

\Return{$\pi^*$} 
\end{algorithm}


